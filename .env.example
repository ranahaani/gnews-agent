# gnews-agent — example environment file
#
# Copy to `.env` (gitignored) and fill in only the keys you need.
# `search`, `ingest`, `timeline`, and `stats` work with NO keys at all.
# `brief` and `sentiment` need exactly one of the LLM provider keys below.

# --- LLM providers (pick one) -----------------------------------------------
# Anthropic — preferred for integration tests (50k TPM free tier).
ANTHROPIC_API_KEY=

# OpenAI — used by the `openai` embedding extra and `brief`/`sentiment`.
OPENAI_API_KEY=

# Groq — fastest + cheapest but tighter TPM on the free tier.
GROQ_API_KEY=

# Gemini.
GEMINI_API_KEY=

# --- Defaults for the CLI (optional) ---------------------------------------
# Match these to whichever provider key is set above.
GNEWS_AGENT_LLM_PROVIDER=anthropic
GNEWS_AGENT_LLM_MODEL=claude-3-5-haiku-latest
